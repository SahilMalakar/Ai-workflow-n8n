APP_NAME=Abacus ERP Simulator
APP_VERSION=1.0.0
DEBUG=true

HOST=127.0.0.1
PORT=8000

# SQLite for local dev — swap for PostgreSQL URL in production
DATABASE_URL=sqlite:///./abacus.db

API_VERSION=v1
API_BASE_PATH=/rest/v1

ABACUS_CLIENT_ID=demo-client
ABACUS_CLIENT_SECRET=demo-secret
ABACUS_MOCK_TOKEN=mock-access-token

TOKEN_EXPIRY_SECONDS=3600

INSTANCE_URL=http://127.0.0.1:8000

ALLOWED_ORIGINS=["*"]
